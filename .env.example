# ─── DATABASE ────────────────────────────────────────────────────────────────
# For local dev (use a local PostgreSQL or Neon dev branch):
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Direct URL (unpooled, for Prisma migrations):
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── NEXTAUTH ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# ─── SIGNWELL (Optional — runs in demo mode if not set) ─────────────────────
# SIGNWELL_API_KEY=""
# SIGNWELL_WEBHOOK_SECRET=""

# ─── HUBSPOT (Optional — uses demo data if not set) ─────────────────────────
# HUBSPOT_PRIVATE_TOKEN=""
# HUBSPOT_PORTAL_ID=""

# ─── REFERRAL WEBHOOK (Optional — no auth if not set) ───────────────────────
# Secret token for Frost Law referral form webhook verification
# REFERRAL_WEBHOOK_SECRET=""

# ─── ANTHROPIC (AI Support Bot — uses mock responses if not set) ────────────
# Get a key at https://console.anthropic.com/settings/keys
# NEVER commit the real key — set it in Vercel env vars for production
# ANTHROPIC_API_KEY=""
# Optional model override (defaults to claude-haiku-4-5)
# ANTHROPIC_MODEL="claude-haiku-4-5"
# Optional daily budget cap in USD (defaults to $5/day)
# AI_DAILY_BUDGET_USD="5"
