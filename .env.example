# ─── BOOTSTRAP ADMIN (Production first-deploy only) ─────────────────────────
# When seeding a NEW database that has zero super_admin users, the seed
# scripts (scripts/seed-all.js + scripts/seed-admin.ts) require these two
# env vars in production to avoid silently creating a default-password
# admin account. Once any super_admin exists in the DB, the seed skips
# admin creation entirely on every subsequent build. These are ONLY for
# the very first deploy of a new environment.
#
# In local dev / preview deploys (NODE_ENV !== "production"), the seed
# falls back to admin@fintella.partners / admin123 if these are unset.
# SEED_ADMIN_EMAIL="you@fintella.partners"
# SEED_ADMIN_PASSWORD="generate-a-strong-unique-password"

# ─── DATABASE ────────────────────────────────────────────────────────────────
# For local dev (use a local PostgreSQL or Neon dev branch):
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Direct URL (unpooled, for Prisma migrations):
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── NEXTAUTH ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# ─── SIGNWELL (Optional — runs in demo mode if not set) ─────────────────────
# SIGNWELL_API_KEY=""
# SIGNWELL_WEBHOOK_SECRET=""

# ─── HUBSPOT (Optional — uses demo data if not set) ─────────────────────────
# HUBSPOT_PRIVATE_TOKEN=""
# HUBSPOT_PORTAL_ID=""

# ─── REFERRAL WEBHOOK (Optional — no auth if not set) ───────────────────────
# Secret token for Frost Law referral form webhook verification
# REFERRAL_WEBHOOK_SECRET=""

# ─── ANTHROPIC (AI Support Bot — uses mock responses if not set) ────────────
# Get a key at https://console.anthropic.com/settings/keys
# NEVER commit the real key — set it in Vercel env vars for production
# ANTHROPIC_API_KEY=""
# Optional model override (defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# Optional daily budget cap in USD (defaults to $5/day)
# AI_DAILY_BUDGET_USD="5"
# Optional daily message limit per partner (defaults to 50)
# AI_DAILY_MESSAGE_LIMIT="50"

# ─── OPENAI WHISPER (Phase 2c — audio transcription for Tara) ──────────────
# Used server-side only to transcribe audio TrainingResources on upload.
# Demo-gated: unset = no transcription, TrainingResource.audioTranscript stays null.
# Whisper pricing ~$0.006/minute; first release caps input at 25MB per file.
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=""
# Optional model override (defaults to whisper-1)
# OPENAI_WHISPER_MODEL="whisper-1"

# ─── SENDGRID (Phase 15a — transactional email, optional / demo mode) ──────
# When unset the portal runs in demo mode: every "send" is recorded to the
# EmailLog table with status="demo" and the admin Communication Log shows
# them as if they had been sent. Set these three to flip on real delivery.
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@fintella.partners"
# SENDGRID_FROM_NAME="Fintella"

# ─── TWILIO (Phase 15b SMS + Phase 15c Voice, optional / demo mode) ─────────
# When any of the three are unset the portal runs in demo mode: every SMS
# "send" is recorded to the SmsLog table with status="demo" and every Voice
# call is recorded to CallLog with status="demo". The admin Communication
# Log shows them as if they had been sent.
#
# TCPA: SMS sends are also gated on Partner.smsOptIn — non-opted-in partners
# never receive SMS even when Twilio is configured (logged with
# status="skipped_optout").
#
# TWILIO_ACCOUNT_SID=""              # AC... from console.twilio.com
# TWILIO_AUTH_TOKEN=""                # secret companion to the SID — also signs Twilio webhooks
# TWILIO_FROM_NUMBER="+15555550100"  # E.164, must be a number you own in Twilio (used as From for SMS + outbound caller ID)
# TWILIO_ADMIN_PHONE="+15555550101"  # E.164, the admin phone Twilio dials FIRST in the bridged voice call flow
#
# Inbound SMS webhook (Phase 15b-fu #2): POST endpoint at
#   https://fintella.partners/api/twilio/webhook
# Configure this URL on your Twilio number's Messaging webhook in the
# Twilio console (Phone Numbers → Manage → Active numbers → your number →
# Messaging Configuration → "A message comes in" → Webhook → POST). The
# route handles STOP / UNSUBSCRIBE / CANCEL / END / QUIT / STOPALL keywords
# (flips Partner.smsOptIn = false) and START / UNSTOP / YES (flips back on).
# Signature verification uses TWILIO_AUTH_TOKEN automatically.
#
# Voice click-to-call (Phase 15c): admin clicks "Call Partner" on
# /admin/partners/[id]; Twilio dials TWILIO_ADMIN_PHONE first, then
# bridges to the partner via TwiML returned by:
#   https://fintella.partners/api/twilio/voice-webhook
# Status callbacks land at:
#   https://fintella.partners/api/twilio/call-status
# Both webhook URLs are passed inline at call origination time — no
# console configuration required for them. Recording is intentionally
# NOT enabled in this initial cut (state-by-state legal disclosure
# requirements; future Phase 15c-followup will add a recorded consent
# prompt + per-state config).

# ─── OPENAI (Embeddings only — text-embedding-3-small for RAG vector search)
# Used server-side only. Chat stays on Anthropic Claude. ~$0.02/1M tokens.
# Demo-gated: unset = RAG falls back to full-text search, no vector embeddings.
# OPENAI_API_KEY=""

# ─── TAVILY (Web research agent — optional) ─────────────────────────────────
# Powers the daily automated knowledge base research. $5/mo at tavily.com.
# Demo-gated: unset = no research cron runs, manual trigger returns empty.
# TAVILY_API_KEY=""
# AI_RESEARCH_ENABLED="false"

# ─── AI TEMPLATE GENERATOR (Phase 19 — GPT-4o for template generation) ─────
# OPENAI_TEMPLATE_MODEL="gpt-4o"
# TEMPLATE_GENERATION_RATE_LIMIT_HOUR="10"
# SMS_DEFAULT_MAX_CHARS="160"

# ─── SENTRY (Error Tracking — Phase 18 monitoring, optional) ────────────────
# Create a project at https://sentry.io → Settings → Projects → Client Keys
# Gracefully no-ops if not set (local dev + previews work without Sentry)
# SENTRY_DSN=""                      # Server-side DSN (secret if private project)
# NEXT_PUBLIC_SENTRY_DSN=""          # Client-side DSN (same value, but public)
# SENTRY_AUTH_TOKEN=""               # Auth token for source map upload at build time
# SENTRY_ORG=""                      # Your Sentry org slug
# SENTRY_PROJECT=""                  # Your Sentry project slug
# SENTRY_TRACES_SAMPLE_RATE="0.1"    # Server traces sample rate (0.0-1.0)
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"  # Client traces sample rate

# ─── WEB PUSH (Ops Center notifications) ────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
# Demo-gated: unset = push notifications disabled, subscribe is a no-op.
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@fintella.partners"
