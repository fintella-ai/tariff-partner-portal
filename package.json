{
  "name": "fintella-partner-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --accept-data-loss && node scripts/seed-all.js 2>&1 && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed-training": "npx ts-node --compiler-options {\"module\":\"commonjs\"} scripts/seed-training.ts",
    "db:seed-conference": "npx ts-node --compiler-options {\"module\":\"commonjs\"} scripts/seed-conference.ts",
    "db:seed-partners": "npx ts-node --compiler-options {\"module\":\"commonjs\"} scripts/seed-partners.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@prisma/client": "^5.20.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.51.0",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "@tavily/core": "^0.7.3",
    "@twilio/voice-sdk": "^2.18.2",
    "@types/pg": "^8.20.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.35.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "twilio": "^5.13.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.11",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  }
}
