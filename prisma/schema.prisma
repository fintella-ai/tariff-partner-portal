generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ADMIN USERS ─────────────────────────────────────────────────────────────
model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  passwordHash          String
  name                  String?
  role                  String   @default("admin") // super_admin, admin, accounting, partner_support
  // PartnerOS AI — Phase 1 persona split (spec §3.6). Slot for future admin AI experience.
  preferredGeneralist   String?  // "finn" | "stella"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

}

// ─── PARTNERS ───────────────────────────────────────────────────────────────
model Partner {
  id                    String   @id @default(cuid())
  partnerCode           String   @unique
  email                 String
  passwordHash          String?  // bcrypt hash, null = legacy (uses partnerCode to log in)
  firstName             String
  lastName              String
  companyName           String?
  title                 String?  // partner's title at their company (e.g. CEO, Founder, Managing Partner). Surfaces in SignWell agreements via the partner_title api_id.
  phone                 String?
  mobilePhone           String?  // international SMS format (+1...)
  tin                   String?  // TIN in ##-####### format
  status                String   @default("active") // active, pending, inactive, blocked
  referredByPartnerCode String?  // who recruited them
  // Commission tier system
  tier                  String   @default("l1")  // "l1", "l2", "l3"
  commissionRate        Float    @default(0.25)   // rate this partner earns on their direct deals (% of firm fee)
  recruitedViaInvite    String?  // token from RecruitmentInvite that created this partner
  // DEPRECATED (Option B Phase 6): L3 recruitment gate was removed; every
  // partner whose rate leaves room below them can recruit. Column retained
  // for rollback safety + read-only compatibility with any legacy tooling.
  // Safe to drop in a future migration when no tooling reads it.
  l3Enabled             Boolean  @default(false)
  // Payout Downline Partners flag — controls whether Fintella pays L2/L3 downline directly (true) or the L1 receives full rate (false)
  payoutDownlineEnabled Boolean  @default(false)
  // Communications opt-in
  emailOptIn            Boolean  @default(false)
  smsOptIn              Boolean  @default(false)
  optInDate             DateTime? // when they consented
  // Metadata
  notes                 String?  // admin notes
  signupDate            DateTime @default(now())
  // Getting-Started checklist state. JSON shape:
  //   { dismissed?: boolean, watchedWelcomeVideoAt?: ISO, firstCallJoinedAt?: ISO,
  //     firstTrainingCompletedAt?: ISO, referralLinkSharedAt?: ISO, completedAt?: ISO }
  // Steps that are derivable from real DB signals (agreement, deals, downline,
  // profile, payout) are computed live in src/lib/getting-started.ts and do NOT
  // live here — this column only tracks actions that aren't otherwise recorded.
  onboardingState       String   @default("{}")
  // PartnerOS AI — Phase 1 persona split (spec §3.6). null = prompt on first AI visit.
  preferredGeneralist   String?  // "finn" | "stella"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([email])
  @@index([referredByPartnerCode])
}

// ─── PARTNER PROFILE (address, payout info) ──────────────────────────────────
model PartnerProfile {
  id              String   @id @default(cuid())
  partnerCode     String   @unique
  // Address
  street          String?
  street2         String?
  city            String?
  state           String?
  zip             String?
  country         String   @default("US")
  phone           String?
  // Payout info (banking for domestic wire)
  payoutMethod    String?  // "wire", "ach", "check"
  bankName        String?
  accountType     String?  // "checking", "savings"
  routingNumber   String?
  accountNumber   String?
  beneficiaryName String?  // name on the account
  bankAddress     String?  // legacy single-line (kept for backward compat)
  bankStreet      String?  // bank branch street address line 1
  bankStreet2     String?  // bank branch street address line 2
  bankCity        String?
  bankState       String?
  bankZip         String?
  paypalEmail     String?
  // Status
  isBlocked       Boolean  @default(false)
  blockReason     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── DOCUMENTS ───────────────────────────────────────────────────────────────
model Document {
  id          String   @id @default(cuid())
  partnerCode String
  docType     String   // "w9", "tax_form", "agreement", "other"
  fileName    String
  fileUrl     String
  fileSize    Int?
  status      String   @default("uploaded") // uploaded, under_review, approved, rejected, expired
  uploadedBy  String   // "partner" or admin user id
  reviewedBy  String?
  reviewedAt  DateTime?
  notes       String?
  required    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── RECRUITMENT INVITES ─────────────────────────────────────────────────────
model RecruitmentInvite {
  id                String    @id @default(cuid())
  token             String    @unique       // URL-safe random token for the signup link
  inviterCode       String?                 // partnerCode of the inviting partner; null for admin-generated L1 invites
  targetTier        String                  // "l1", "l2", or "l3"
  commissionRate    Float                   // 0.25 for l1; 0.10/0.15/0.20 for l2; 0.10/0.15 for l3
  status            String    @default("active") // active, used, expired
  usedByPartnerCode String?                 // filled when someone signs up with this invite
  invitedEmail      String?                 // email the admin invite was sent to (L1 only)
  invitedName       String?                 // display name for the invite email (L1 only)
  expiresAt         DateTime?
  payoutDownlineEnabled Boolean  @default(false) // Payout Downline Partners flag — carried forward from admin's choice to the Partner row at signup
  // Last time the invite-reminder cron fired for this row. Null = never.
  // Used by /api/cron/reminders to enforce the `cadenceDays` gap between
  // reminder emails/SMS for the same unused invite.
  lastReminderSentAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([token])
  @@index([inviterCode])
}

// ─── PARTNERSHIP AGREEMENTS ──────────────────────────────────────────────────
model PartnershipAgreement {
  id                    String   @id @default(cuid())
  partnerCode           String
  version               Int      @default(1)
  signwellDocumentId    String?
  embeddedSigningUrl    String?  // Signing URL for partner (opens in new tab)
  cosignerSigningUrl    String?  // Signing URL for Fintella co-signer
  templateRate          Float?   // the commission rate this agreement is for (0.25, 0.20, 0.15, 0.10)
  templateId            String?  // SignWell template ID used for this agreement
  status                String   @default("not_sent") // not_sent, pending, signed, amended
  sentDate              DateTime?
  signedDate            DateTime?
  documentUrl           String?
  // Last time the agreement-reminder cron fired for this row. Null = never.
  // Used by /api/cron/reminders to enforce the `cadenceDays` gap between
  // reminder emails/SMS for the same unsigned agreement.
  lastReminderSentAt    DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([partnerCode])
}

// ─── SUPPORT TICKETS ─────────────────────────────────────────────────────────
model SupportTicket {
  id          String   @id @default(cuid())
  partnerCode String
  subject     String
  category    String   // "deal_tracking", "tech_error", "portal_question", "commission_question", "other"
  status      String   @default("open") // open, in_progress, resolved, closed
  priority    String   @default("normal") // low, normal, high, urgent
  adminNotes  String?  // internal only
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages TicketMessage[]

  @@index([partnerCode])
  @@index([status])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  authorType String   // "partner" or "admin"
  authorId   String   // partnerCode or admin userId
  content    String
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────
model Notification {
  id          String   @id @default(cuid())
  recipientType String // "partner" or "admin"
  recipientId   String // partnerCode or admin userId
  type        String   // "deal_update", "commission_paid", "document_request", "ticket_response", etc.
  title       String
  message     String
  read        Boolean  @default(false)
  link        String?  // optional deep link
  createdAt   DateTime @default(now())

  @@index([recipientId, read])
}

// ─── COMMISSION LEDGER ───────────────────────────────────────────────────────
model CommissionLedger {
  id             String   @id @default(cuid())
  partnerCode    String
  dealId         String
  dealName       String?
  tier           String   // "l1", "l2", "l3"
  amount         Float
  // Status lifecycle (three phase):
  //   pending — deal has closed_won but firm has not yet paid Fintella the override.
  //             Created automatically by the /api/webhook/referral PATCH handler
  //             when Frost Law first marks the deal closed_won.
  //   due     — admin has confirmed payment via "Mark Payment Received" on
  //             /admin/deals. Ready to be batched into a PayoutBatch.
  //   paid    — the payout batch has been processed.
  status         String   @default("pending")
  periodMonth    String?  // "2025-03" format
  payoutDate     DateTime?
  payoutMethod   String?
  payoutReference String?
  batchId           String?
  stripeTransferId  String?  // Stripe Transfer ID (tr_xxx) — populated by process_batch when partner has a connected account
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  batch PayoutBatch? @relation(fields: [batchId], references: [id])

  // Belt-and-suspenders: only one ledger row per (deal, partner, tier). Prevents
  // duplicates if the webhook retries or if a deal somehow hits closed_won twice.
  // The webhook's idempotency check + this constraint together guarantee at-most-one
  // ledger row per partner-per-tier-per-deal regardless of replay patterns.
  @@unique([dealId, partnerCode, tier])
  @@index([partnerCode])
  @@index([status])
  @@index([batchId])
}

// ─── PAYOUT BATCHES ──────────────────────────────────────────────────────────
model PayoutBatch {
  id            String   @id @default(cuid())
  totalAmount   Float
  partnerCount  Int
  status        String   @default("draft") // draft, approved, processed
  processedDate DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  commissions CommissionLedger[]
}

// ─── TRAINING MODULES ────────────────────────────────────────────────────────
model TrainingModule {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   // "onboarding", "sales", "product", "tools"
  content     String?  // rich text / markdown
  videoUrl    String?
  duration    String?  // e.g., "12 min", "18 min"
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrainingProgress {
  id          String   @id @default(cuid())
  partnerCode String
  moduleId    String
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([partnerCode, moduleId])
}

// ─── TRAINING RESOURCES ──────────────────────────────────────────────────────
model TrainingResource {
  id          String   @id @default(cuid())
  moduleId    String?  // null = general resource not tied to a module
  // Category is independent of the linked module (admin may want a resource
  // in a different category than its parent module). Null = inherit from
  // the linked module (if any). Free-form string; the admin UI surfaces the
  // set of categories currently in use for autocomplete.
  category    String?
  title       String
  description String?
  fileUrl     String
  fileType    String   // "pdf", "checklist", "template", "guide"
  fileSize    String?  // "1.2 MB"
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── PARTNER CODE HISTORY (audit trail for code changes) ────────────────────
model PartnerCodeHistory {
  id              String   @id @default(cuid())
  partnerId       String   // Partner record ID (stable, never changes)
  oldCode         String   // the code that was replaced
  newCode         String   // the new code that replaced it
  changedBy       String   // admin email who made the change
  createdAt       DateTime @default(now())

  @@index([partnerId])
  @@index([oldCode])
}

// ─── ADMIN NOTES (immutable audit log) ───────────────────────────────────────
model AdminNote {
  id             String   @id @default(cuid())
  partnerCode    String
  content        String
  authorName     String   // admin who posted the note
  authorEmail    String
  isPinned       Boolean  @default(false)
  // Legacy single-attachment columns (PR #356). Superseded by the
  // NoteAttachment child table but retained for historical rows + as a
  // fallback read path. Don't write here for new notes.
  attachmentName String?
  attachmentUrl  String?
  attachmentType String?
  attachmentSize Int?
  createdAt      DateTime @default(now())

  attachments    NoteAttachment[]

  @@index([partnerCode])
}

// ─── DEAL NOTES (immutable audit log) ────────────────────────────────────────
model DealNote {
  id          String   @id @default(cuid())
  dealId      String
  content     String
  authorName  String
  authorEmail String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  sourceChatMessageId String?  // when DealNote was mirrored from an AdminChatMessage

  attachments NoteAttachment[]

  @@index([dealId])
  @@index([sourceChatMessageId])
}

// Polymorphic attachment shared by AdminNote + DealNote. Exactly one of
// `adminNoteId` or `dealNoteId` is set per row — NOT enforced in the
// schema, enforced by the API route that always scopes inserts to one.
// `url` stores a base64 data URL today (same pattern as Document.fileUrl);
// a future migration can swap this to an object-storage URL (Vercel Blob
// / R2 / S3) without touching consumers.
model NoteAttachment {
  id          String   @id @default(cuid())
  adminNoteId String?
  dealNoteId  String?
  name        String
  url         String
  type        String?
  size        Int?
  createdAt   DateTime @default(now())

  adminNote   AdminNote? @relation(fields: [adminNoteId], references: [id], onDelete: Cascade)
  dealNote    DealNote?  @relation(fields: [dealNoteId], references: [id], onDelete: Cascade)

  @@index([adminNoteId])
  @@index([dealNoteId])
}

// ─── IMPERSONATION TOKENS ───────────────────────────────────────────────────
model ImpersonationToken {
  id          String   @id @default(cuid())
  token       String   @unique
  partnerCode String
  email       String
  name        String
  used        Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([token])
}

// ─── PASSKEYS (WebAuthn) ────────────────────────────────────────────────────
// One row per passkey enrolled by a partner. A single partner can have many
// passkeys (phone, laptop, hardware key), and a passkey synced across Apple
// iCloud Keychain or Google Password Manager still shows up as a separate
// row per device it's registered on — the `credentialId` is the source of
// truth for uniqueness.
model Passkey {
  id               String   @id @default(cuid())
  partnerCode      String
  credentialId     String   @unique // base64url-encoded CredentialID from the authenticator
  publicKey        Bytes    // CBOR-encoded public key for signature verification
  counter          BigInt   @default(0) // authenticator signature counter, used for anti-clone detection
  transports       String   @default("") // JSON array of WebAuthn transports ("internal","usb","nfc","ble","hybrid")
  deviceType       String   @default("") // "singleDevice" | "multiDevice" (from AuthenticatorAttachment)
  backedUp         Boolean  @default(false) // whether the credential is synced to a cloud backup
  name             String?  // optional friendly label the partner can set (e.g. "iPhone 15", "YubiKey")
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime?

  @@index([partnerCode])
  @@index([credentialId])
}

// Short-lived WebAuthn challenges. One row per pending
// registration / authentication handshake. The options endpoint writes
// the challenge it generated; the verify endpoint reads + deletes it.
// TTL is 5 minutes — the purge query runs opportunistically inside
// verify handlers (no cron required).
model PasskeyChallenge {
  id          String   @id @default(cuid())
  challenge   String   @unique
  purpose     String   // "register" | "login"
  partnerCode String?  // set for register (the user enrolling); null for login (we don't know who yet)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([challenge])
  @@index([expiresAt])
}

// ─── FREQUENTLY ASKED QUESTIONS ──────────────────────────────────────────────
model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String   // markdown
  category    String   @default("general") // "general", "commissions", "leads", "technical"
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CONFERENCE SCHEDULE ─────────────────────────────────────────────────────
model ConferenceSchedule {
  id           String    @id @default(cuid())
  title        String
  description  String?
  embedUrl     String?   // YouTube/Vimeo embed URL for recording playback
  joinUrl      String?   // Direct join link (Zoom/Meet) — legacy; prefer jitsiRoom
  recordingUrl String?   // External fallback URL for recording
  schedule     String?   // "Weekly, Thursdays at 2pm ET"
  nextCall     DateTime?
  hostName     String?   // Presenter name
  duration     String?   // e.g., "52 min"
  weekNumber   Int?      // For labeling, e.g., 12 for "Week 12"
  notes        String?   // Markdown meeting notes/summary
  isActive     Boolean   @default(true)
  // ── Jitsi in-portal embed ──
  // Auto-generated room slug. Partners embed the room in-portal via
  // iframe at https://meet.jit.si/<jitsiRoom>. Empty = fall back to
  // legacy joinUrl (Zoom/Meet in new tab).
  jitsiRoom              String?
  // ── Google Calendar sync ──
  // Populated by /api/admin/conference/[id]/sync-to-calendar once the
  // admin pushes the row to the configured shared Google Calendar.
  googleCalendarEventId  String?
  googleCalendarHtmlLink String?
  // ── Reminder automation dedup ──
  // Array of Workflow IDs for trigger=conference.call_reminder that
  // have already fired for this row. Reset automatically when the row
  // is created (null = never fired). Prevents the hourly cron from
  // re-firing the same reminder within a single scheduled call.
  firedReminderWorkflows Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── PORTAL SETTINGS ────────────────────────────────────────────────────────
model PortalSettings {
  id        String @id @default("global") // singleton — always "global"
  // Branding
  firmName  String @default("Financial Intelligence Network")
  firmShort String @default("Fintella")
  firmSlogan String @default("Fighting for what's owed, reclaiming what's fair.")
  firmPhone String @default("(410) 497-5947")
  supportEmail String @default("")
  // Branding images (stored as base64 data URLs)
  logoUrl      String @default("")  // company logo (displayed in sidebar)
  faviconUrl   String @default("")  // favicon (displayed in browser tab)
  // Commission Rates (stored as decimals: 0.25 = 25%)
  firmFeeRate        Float   @default(0.20)
  maxCommissionRate  Float   @default(0.25) // L1 rate / total cap (25%)
  l1Rate             Float   @default(0.25) // L1 direct deal rate
  l2Rate             Float   @default(0.05) // legacy default
  l3Rate             Float   @default(0)    // legacy default
  // DEPRECATED (Option B Phase 6): the global L3 gate is gone; Phase 2
  // onward allows every L2 to recruit L3. Column retained for rollback
  // safety; safe to drop in a future migration.
  l3Enabled          Boolean @default(false)
  // Agreement templates (SignWell template IDs per rate)
  // Master SignWell template — one template for every standard partner
  // agreement. The recruit's actual commission rate is interpolated into
  // the template body via a placeholder at send time, so per-rate-bucket
  // templates are no longer needed. Introduced in Option B Phase 3;
  // resolveAgreementTemplateId prefers this field when set, falling
  // back to the legacy per-rate fields below when it's empty so admins
  // can migrate at their own pace. Legacy fields drop in Phase 6.
  agreementTemplateMaster String @default("")
  // Legacy per-rate templates (deprecated). Still read as a fallback
  // when agreementTemplateMaster is empty.
  agreementTemplate25 String @default("") // 25% agreement template
  agreementTemplate20 String @default("") // 20% agreement template
  agreementTemplate15 String @default("") // 15% agreement template
  agreementTemplate10 String @default("") // 10% agreement template
  agreementTemplateEnterprise String @default("") // Enterprise partner agreement template
  // Fintella co-signer — the second recipient on every agreement. Lets
  // Fintella countersign alongside the partner without the sender having
  // to do it manually in the SignWell dashboard. The placeholder name
  // must exactly match the second recipient's role in every SignWell
  // template (defaults to "Fintella").
  fintellaSignerName        String  @default("")
  fintellaSignerEmail       String  @default("")
  fintellaSignerPlaceholder String  @default("Fintella")
  // Google Calendar OAuth — super-admin connects their own Google account
  // once via /admin/settings → "Connect Google Calendar". Refresh token
  // is stored long-term; access token is re-minted from it on each API
  // call (short-lived + cached in memory). Empty string = disconnected.
  googleCalendarRefreshToken String @default("")
  googleCalendarConnectedEmail String @default("")
  googleCalendarCalendarId     String @default("primary") // "primary" or an explicit calendar id
  googleCalendarConnectedAt    DateTime?
  // Navigation visibility + order (JSON strings)
  hiddenNavItems String @default("[]")
  navOrder       String @default("[]")  // ordered array of partner nav IDs
  adminNavOrder  String @default("[]")  // ordered array of admin nav IDs
  // Per-item label + icon overrides. JSON shape:
  //   { "admin.partners": "Team", "partner.home": "Dashboard" }
  // navIcons values are base64 data URLs (same storage as logoUrl), so an
  // uploaded PNG / SVG replaces the default emoji glyph. Keys namespace
  // by scope so admin + partner sides can override the same short id.
  navLabels      String @default("{}")
  navIcons       String @default("{}")
  // Home page content (JSON strings)
  announcements  String @default("[]")
  upcomingEvents String @default("[]")
  referralOpportunities String @default("[]")
  leaderboardEnabled     Boolean @default(true)
  // Optional embedded video rendered under the welcome header on the
  // partner home page. Accepts any URL the browser can embed in an
  // <iframe src> — YouTube, Vimeo, Loom, Wistia, Mux, hosted MP4, etc.
  homeEmbedVideoUrl      String?
  // Per-module visibility for the partner home page. JSON array of
  // module IDs the admin has turned OFF. Recognized IDs: "video",
  // "announcements", "events", "opportunities", "leaderboard".
  // Keeps data intact (admin can re-enable later) rather than forcing
  // a destructive delete when they want to temporarily hide a section.
  homeHiddenModules      String @default("[]")
  // Order of Home-page modules as laid out by the admin. JSON array of
  // module IDs (same IDs as homeHiddenModules). Unknown IDs tolerated
  // for forward-compat; missing IDs from a future release fall back to
  // the default tail order.
  homeModuleOrder        String @default("[\"video\",\"events\",\"announcements\",\"leaderboard\",\"opportunities\"]")
  // Per-module layout config for the partner Home page. JSON map of
  // { moduleId: { columns: 1|2|3, alignment: "left"|"center" } }.
  // - columns applies to card-grid modules (events, announcements, opportunities)
  // - alignment applies to every module (center uses max-w-4xl mx-auto, left is full-width)
  // Missing keys fall back to sensible defaults in the render layer.
  homeModuleLayout       String @default("{}")
  liveChatEnabled        Boolean @default(false) // live support chat on/off
  callRecordingEnabled   Boolean @default(false) // record outbound voice calls (requires Twilio)
  // Optional banner image shown centered at the top of the partner
  // Live Weekly Call page. base64 data URL (same storage as logoUrl).
  // Empty string = no banner, page renders without it.
  liveWeeklyBannerUrl    String  @default("")
  // Active portal theme id — matches one of the presets in
  // src/lib/portalThemes.ts. "default" (which is the value at schema
  // bootstrap) is a no-op override that preserves the exact globals.css
  // baseline, so rollback from any other theme is guaranteed-safe.
  activeThemeId          String  @default("default")
  // Per-admin theme customizations layered on top of the base preset.
  // JSON shape: { accentColor?: string, fontFamily?: string,
  // buttonStyle?: "rounded"|"pill"|"square" }. Empty object = no extra
  // overrides. Applied last in the cascade so they win over both
  // globals.css and the preset's own overrides.
  themeCustomizations    String  @default("{}")
  // Partner Getting-Started expectations copy shown on /dashboard/getting-started.
  // Markdown-rendered. When null, src/lib/getting-started.ts renders the hardcoded
  // default copy so new portals aren't blank on day one.
  gettingStartedExpectations String?
  // Timestamps
  updatedAt DateTime @updatedAt
}

// ─── DEALS ──────────────────────────────────────────────────────────────────
model Deal {
  id                    String    @id @default(cuid())
  dealName              String
  partnerCode           String    // submitting partner
  // Client contact info
  clientFirstName       String?
  clientLastName        String?
  clientName            String?   // legacy / computed display name
  clientEmail           String?
  clientPhone           String?
  clientTitle           String?   // business title (e.g. CEO, CFO)
  // Service & business details
  serviceOfInterest     String?   // "Tariff Refund Support", "ERC Support", "Kwong Penalty Abatement"
  legalEntityName       String?   // Legal Entity / Business Name
  businessCity          String?
  businessState         String?
  importsGoods          String?   // "Yes", "No"
  importCountries       String?   // countries they import from
  annualImportValue     String?   // dropdown value (e.g. "$1M - $5M")
  importerOfRecord      String?   // who is listed as importer of record
  affiliateNotes        String?   // affiliate notes from referral form
  // Enterprise Partner tracking — carried via utm_medium on the client-submission
  // link when the referring partner is an Enterprise Account reselling their own
  // downstream L1s. Raw string, no normalization (EA's own coding). Set ONLY on
  // the initial POST to /api/webhook/referral; status-update PATCHes do not
  // touch this field. Editable in admin only by super_admin. Used later to
  // post status updates back to the EA's portal keyed on this value.
  epLevel1              String?
  // Deal tracking
  stage                 String    @default("new_lead")
  externalStage         String?   // raw deal stage from external system (Frost Law / HubSpot)
  externalDealId        String?   @unique  // network-assigned ID (HubSpot's hs_object_id, or outbound network's returned ID)
  rawPayload            String?            // last raw inbound payload JSON (failsafe for fields we didn't map to columns)
  consultBookedDate     String?   // consultation date (YYYY-MM-DD or display format)
  consultBookedTime     String?   // consultation time (HH:MM or display format)
  productType           String?   // "ieepa", "section301", "other"
  importedProducts      String?   // description of goods
  estimatedRefundAmount Float     @default(0)
  actualRefundAmount    Float?    // set when Frost Law confirms the actual refund check the client received (post closed_won)
  firmFeeRate           Float?    // negotiated per deal
  firmFeeAmount         Float     @default(0)
  // Commissions
  l1CommissionRate      Float?
  l1CommissionAmount    Float     @default(0)
  l1CommissionStatus    String    @default("pending")
  l2CommissionAmount    Float     @default(0)
  l2CommissionStatus    String    @default("pending")
  l3CommissionAmount    Float     @default(0)
  l3CommissionStatus    String    @default("pending")
  // Notes
  notes                 String?
  closedLostReason      String?   // reason if stage moved to closedlost
  closeDate             DateTime?
  // Payment received (admin confirms Frost Law has paid Fintella the override —
  // this is the trigger that flips L1/L2/L3 commissions from "pending" to "due"
  // and creates CommissionLedger rows so the payout batch flow can pick them up)
  paymentReceivedAt     DateTime?
  paymentReceivedBy     String?   // admin email who clicked Mark Payment Received
  // Webhook idempotency — if a POST to /api/webhook/referral includes an
  // idempotencyKey, we store it here and any re-POST with the same key
  // returns the existing dealId with HTTP 200 instead of creating a duplicate.
  idempotencyKey        String?   @unique
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([partnerCode])
  @@index([stage])
}

// ─── ENTERPRISE PARTNERS ────────────────────────────────────────────────────
// An Enterprise Partner receives a custom commission rate higher than the
// standard 25% L1 rate. The "override" (total rate minus 25%) is earned on
// all L1 partners placed under them via EnterpriseOverride records.
// Example: 30% total → 5% override on each assigned L1 partner's deals.
model EnterprisePartner {
  id              String   @id @default(cuid())
  partnerCode     String   @unique           // must be an existing active Partner
  totalRate       Float                      // e.g. 0.30 for 30%
  overrideRate    Float                      // totalRate - 0.25 (auto-calculated, stored for convenience)
  applyToAll      Boolean  @default(false)   // if true, override applies to ALL partners in the portal (no need to add individual codes)
  status          String   @default("active") // active, inactive
  notes           String?
  createdBy       String?                    // admin email who created
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  overrides EnterpriseOverride[]
}

// Each record assigns an L1 partner under an Enterprise Partner.
// The Enterprise Partner earns overrideRate on all deals by this L1.
model EnterpriseOverride {
  id                    String   @id @default(cuid())
  enterprisePartnerCode String                // the enterprise partner's code
  l1PartnerCode         String                // the L1 partner placed under them
  status                String   @default("active") // active, removed
  createdBy             String?               // admin email
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  enterprise EnterprisePartner @relation(fields: [enterprisePartnerCode], references: [partnerCode])

  @@unique([enterprisePartnerCode, l1PartnerCode])
  @@index([enterprisePartnerCode])
  @@index([l1PartnerCode])
}

// ─── LIVE CHAT ──────────────────────────────────────────────────────────────
model ChatSession {
  id          String   @id @default(cuid())
  partnerCode String
  status      String   @default("active") // active, closed
  subject     String?  // optional subject/first message preview
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages ChatMessage[]

  @@index([partnerCode])
  @@index([status])
}

model ChatMessage {
  id          String   @id @default(cuid())
  sessionId   String
  senderType  String   // "partner" or "admin"
  senderId    String   // partnerCode or admin email
  senderName  String?
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ─── ADMIN TEAM CHAT (internal, admin-only collaboration) ───────────────────

model AdminChatThread {
  id            String   @id @default(cuid())
  type          String   // "global" | "deal"
  dealId        String?  @unique
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages   AdminChatMessage[]
  readStates AdminChatReadState[]

  @@index([type])
  @@index([lastMessageAt])
}

model AdminChatMessage {
  id              String    @id @default(cuid())
  threadId        String
  senderEmail     String
  senderName      String
  content         String
  parentMessageId String?
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())

  thread   AdminChatThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  mentions AdminChatMention[]

  @@index([threadId, createdAt])
  @@index([parentMessageId])
}

model AdminChatMention {
  id                  String    @id @default(cuid())
  messageId           String
  mentionedAdminEmail String
  notifiedAt          DateTime?
  acknowledgedAt      DateTime?
  createdAt           DateTime  @default(now())

  message AdminChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([mentionedAdminEmail])
  @@index([messageId])
}

model AdminChatReadState {
  id                String   @id @default(cuid())
  threadId          String
  adminEmail        String
  lastReadMessageId String?
  lastReadAt        DateTime @default(now())

  thread AdminChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, adminEmail])
  @@index([adminEmail])
}

// ─── FEATURE REQUESTS ───────────────────────────────────────────────────────
model FeatureRequest {
  id              String   @id @default(cuid())
  title           String
  description     String
  priority        String   @default("normal") // low, normal, high, urgent
  status          String   @default("submitted") // submitted, in_review, in_progress, completed, rejected
  submittedBy     String   // partnerCode or admin email
  submittedByType String   // "partner" or "admin"
  submittedByName String?  // display name
  adminNotes      String?  // super admin internal notes
  category        String?  // "ui", "feature", "bug", "integration", "other"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([submittedBy])
}

// ─── AI ASSISTANT (Fintella PartnerOS) ─────────────────────────────────────
model AiConversation {
  id          String      @id @default(cuid())
  userId      String      // partnerCode or admin email
  userType    String      // "partner" | "admin"
  title       String?     // auto-generated from first message
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  messages    AiMessage[]

  @@index([userId])
  @@index([updatedAt])
}

model AiMessage {
  id                  String   @id @default(cuid())
  conversationId      String
  role                String   // "user" | "assistant"
  content             String   // message text
  inputTokens         Int?     // for cost tracking
  outputTokens        Int?
  cachedTokens        Int?     // DEPRECATED: prompt cache hit tokens (mirrors cacheReadTokens for rows written before the split). Retained so historical rows still render.
  cacheReadTokens     Int?     // tokens served from an existing prompt cache block (cheap — $0.30/MTok on Sonnet 4.6)
  cacheCreationTokens Int?     // tokens written into a new cache block as part of this request (expensive — $3.75/MTok on Sonnet 4.6, ~12x cache read)
  // PartnerOS AI Phase 17b persona system (spec §8.1)
  speakerPersona      String?  // "finn" | "stella" | "tara" | "ollie"; null for user messages
  handoffMetadata     Json?    // { from, to, reason, summary, triggeredBy } — populated when a specialist handoff fires (Phase 2+)
  attachments         Json?    // [{ url, mimeType, width, height }] — populated for bug-triage screenshots (Phase 3)
  createdAt           DateTime @default(now())
  conversation        AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// Singleton row whose value is embedded in Tara's cached system prompt
// (as an HTML comment). Bumping the value invalidates Anthropic's exact-
// match prompt cache, forcing a fresh cache block write on next request.
// See src/lib/ai-knowledge-version.ts for the bump helper; called from
// every training/FAQ mutation route.
model AiKnowledgeVersion {
  id          String    @id @default("singleton")
  version     BigInt    @default(0)
  updatedAt   DateTime  @updatedAt
}

// Per-user rate limit + budget tracking (resets daily)
model AiUsageDay {
  id           String   @id @default(cuid())
  userId       String
  date         String   // YYYY-MM-DD
  messageCount Int      @default(0)
  totalCostUsd Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
}

// ─── EMAIL TEMPLATES ─────────────────────────────────────────────────────────
// Editable transactional email templates. Each row is a template that the
// admin Communications Hub can edit. The `key` field is what `src/lib/sendgrid.ts`
// looks up at send time — for the four wired templates (welcome, agreement_ready,
// agreement_signed, signup_notification) the key matches the existing helper
// names in the lib, and editing the row in the DB changes what gets sent on
// the next real partner event. Templates with `isDraft = true` are placeholder
// stubs in the UI that aren't yet wired to any code path (deal_status_update,
// commission_payment_notification, monthly_newsletter — added per the
// admin/communications mock UI that John wanted persisted).
//
// Variable interpolation: subject / heading / bodyHtml / bodyText / ctaLabel /
// ctaUrl / preheader all support {variable} substitution. Each template
// declares its supported variables in the `variables` JSON field as a hint to
// the admin Edit form. HTML fields are HTML-escaped on substitution; plain
// text fields are not.
model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique             // welcome, agreement_ready, ... (matches sendgrid.ts lookup keys)
  name        String                       // display name in the Communications Hub UI
  category    String                       // Onboarding, Deal Updates, Commissions, Company Updates, etc.
  subject     String                       // email subject line (supports {variables})
  preheader   String?                      // hidden preview text shown by inbox clients
  heading     String                       // h1 heading inside the email body shell
  bodyHtml    String                       // HTML body content (wrapped in shell at send time)
  bodyText    String                       // plain text body content (wrapped at send time)
  ctaLabel    String?                      // CTA button label (optional)
  ctaUrl      String?                      // CTA button URL (optional, supports {variables})
  fromEmail   String?                      // override SENDGRID_FROM_EMAIL env var per template
  fromName    String?                      // override SENDGRID_FROM_NAME env var per template
  replyTo     String?                      // reply-to header (defaults to from address)
  enabled     Boolean  @default(true)      // soft-disable without deleting; disabled templates fall back to hardcoded
  isDraft     Boolean  @default(false)     // unwired placeholder for future automation work
  description String?                      // admin-facing notes about when this template fires
  variables   String?                      // JSON array of variable names available for interpolation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
}

// ─── EMAIL LOG (Phase 15a — SendGrid) ────────────────────────────────────────
// Every outbound transactional email is logged here, whether it went out via
// the real SendGrid API or was a demo/no-op send. Surfaces in the admin
// partner detail Communication Log → Email tab.
model EmailLog {
  id                String   @id @default(cuid())
  partnerCode       String?  // nullable so we can log sends to non-partners (e.g. inviters who haven't onboarded yet)
  toEmail           String
  fromEmail         String
  subject           String
  bodyPreview       String   // first ~300 chars of the plain-text body, for the comm log
  template          String   // "welcome", "agreement_ready", "agreement_signed", "signup_notification", "manual", etc.
  status            String   // "sent", "demo", "failed"
  providerMessageId String?  // SendGrid X-Message-Id header (real sends only)
  errorMessage      String?  // populated on failure
  createdAt         DateTime @default(now())

  @@index([partnerCode])
  @@index([createdAt])
}

// ─── EMAIL EVENT (SendGrid Event Webhook) ───────────────────────────────────
// SendGrid's Event Webhook POSTs delivery + engagement events back to us
// at /api/sendgrid/event-webhook. Each event has a `sg_message_id` whose
// first segment matches EmailLog.providerMessageId, so we denormalize
// `template` + `partnerCode` from the matched EmailLog at insert time for
// fast per-template / per-partner aggregation.
model EmailEvent {
  id                String   @id @default(cuid())
  providerMessageId String   // EmailLog.providerMessageId (X-Message-Id). Foreign-key-lite — no cascade, webhook events may arrive for logs that got pruned
  sgMessageId       String?  // full sg_message_id (providerMessageId prefixed with provider-side suffixes)
  event             String   // processed, delivered, open, click, bounce, dropped, deferred, spamreport, unsubscribe, group_unsubscribe, group_resubscribe
  email             String
  timestamp         DateTime // event time from the webhook payload
  reason            String?  // bounce / dropped reason (failure category)
  bounceType        String?  // hard / soft / blocked
  url               String?  // click URL
  userAgent         String?  // open/click user-agent
  ip                String?
  template          String?  // denormalized from EmailLog.template (null when we can't match)
  partnerCode       String?  // denormalized from EmailLog.partnerCode
  createdAt         DateTime @default(now())

  @@index([providerMessageId])
  @@index([template])
  @@index([event])
  @@index([createdAt])
  @@index([partnerCode])
}

// ─── INBOUND EMAIL (SendGrid Inbound Parse) ─────────────────────────────────
// Every email received at *@inbound.fintella.partners is POSTed by SendGrid's
// Inbound Parse webhook to /api/webhook/inbound-email and persisted here.
// The admin /communications Inbox tab reads from this table, and replies
// (sent via SendGrid API) are logged to the existing EmailLog with a
// threadKey link so the conversation is recomposable.
//
// Thread association: if the "to" address uses plus-addressing with a ticket
// token (e.g. support+tkt_abc123@inbound.fintella.partners), we stash the
// token in supportTicketId so the ticket view can pull the thread.
model InboundEmail {
  id                String   @id @default(cuid())
  messageId         String?  @unique // RFC 5322 Message-ID header for dedup
  fromEmail         String
  fromName          String?
  toEmail           String   // the *@inbound.fintella.partners address we received on
  subject           String
  textBody          String   // plain-text body (may be empty if sender only sent HTML)
  htmlBody          String?  // HTML body when present
  rawHeaders        String?  // full header block for audit / debugging
  spamScore         Float?   // SendGrid's spam score (0..high number)
  partnerCode       String?  // resolved from fromEmail → Partner.email if matched
  supportTicketId   String?  // resolved from plus-addressing token if present
  threadKey         String?  // normalized thread key (In-Reply-To / References) for grouping
  read              Boolean  @default(false)
  replied           Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([createdAt])
  @@index([partnerCode])
  @@index([supportTicketId])
  @@index([threadKey])
}

// ─── SMS LOG (Phase 15b — Twilio Programmable Messaging) ─────────────────────
// Mirrors EmailLog. Every outbound SMS lands here, including TCPA opt-out
// short-circuits ("skipped_optout" status) so the audit trail captures both
// what was sent AND what was suppressed for compliance reasons.
//
// Phase 15b-fu #2: also captures inbound messages from the Twilio webhook
// (STOP / START / other), distinguished by the `direction` field. Inbound
// rows trigger Partner.smsOptIn flips at the route level; this table is
// the single source of truth for both directions of SMS traffic.
// ─── SMS TEMPLATE (Phase 17c) ────────────────────────────────────────────────
// Counterpart to EmailTemplate — admin-editable bodies for the four hardcoded
// transactional SMS kinds (welcome / agreement_ready / agreement_signed /
// signup_notification). Each send helper in src/lib/twilio.ts tries this
// table first; when a row is missing, disabled, or the DB lookup throws,
// the helper falls back to the hardcoded body so partner-facing flows never
// break on a template-table outage.
//
// Default enabled=false for every row while Twilio A2P 10DLC approval is
// still pending. Flip to enabled=true per-template after A2P lands.
model SmsTemplate {
  id          String   @id @default(cuid())
  key         String   @unique  // welcome / agreement_ready / ...
  name        String
  category    String   // Onboarding / Deal Updates / Commissions / Recruitment / Opt-In
  body        String   // plain text — keep under ~140 chars for single GSM-7 segment
  enabled     Boolean  @default(false)
  isDraft     Boolean  @default(false)
  description String?
  variables   String?  // JSON-stringified array of {token, description} — display in editor
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
}

model SmsLog {
  id                String   @id @default(cuid())
  partnerCode       String?  // nullable so we can log sends to recipients without a partner record
  direction         String   @default("outbound") // "outbound" | "inbound"
  toPhone           String   // E.164 format (+1...) — destination for outbound, our number for inbound
  fromPhone         String   // configured TWILIO_FROM_NUMBER for outbound, partner's number for inbound
  body              String   // full message body — SMS is short, no need to truncate
  template          String   // outbound: "welcome"/"agreement_ready"/etc. inbound: "stop_keyword"/"start_keyword"/"inbound_other"
  status            String   // "sent", "demo", "failed", "skipped_optout", "received"
  providerMessageId String?  // Twilio Message SID
  errorMessage      String?  // populated on failure
  createdAt         DateTime @default(now())

  @@index([partnerCode])
  @@index([createdAt])
  @@index([direction])
}

// ─── STRIPE CONNECT (Phase 16) ──────────────────────────────────────────────
// One row per partner who has started or completed Stripe Express onboarding.
// status lifecycle: pending → onboarding → active (ready to receive transfers)
//                                        ↘ restricted (needs attention)
model StripeAccount {
  id               String   @id @default(cuid())
  partnerCode      String   @unique
  stripeAccountId  String   @unique          // acct_xxx
  status           String   @default("pending") // pending, onboarding, active, restricted
  chargesEnabled   Boolean  @default(false)
  payoutsEnabled   Boolean  @default(false)
  detailsSubmitted Boolean  @default(false)
  country          String   @default("US")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([partnerCode])
}

// ─── CALL LOG (Phase 15c — Twilio Voice) ─────────────────────────────────────
// Every outbound voice call initiated from the admin partner detail page
// lands here. The status field is updated by Twilio's status callback
// webhook as the call progresses (initiated → ringing → in-progress →
// completed / failed / no-answer / busy / canceled). Recording URLs and
// durations are populated when Twilio finishes recording (if recording
// was enabled at call initiation).
model CallLog {
  id                String   @id @default(cuid())
  partnerCode       String?  // nullable so we can log calls to non-partner numbers
  direction         String   @default("outbound") // "outbound" | "inbound" (inbound reserved for future)
  toPhone           String   // E.164 — partner's number for outbound
  fromPhone         String   // E.164 — TWILIO_FROM_NUMBER or TWILIO_ADMIN_PHONE
  initiatedByEmail  String?  // admin user email who clicked "Call Partner"
  initiatedByName   String?  // admin display name for the comm log
  status            String   // "initiated"|"ringing"|"in-progress"|"completed"|"failed"|"no-answer"|"busy"|"canceled"|"demo"
  durationSeconds   Int?     // populated by Twilio status callback on completion
  recordingUrl      String?  // populated by Twilio recording webhook (if recording enabled)
  recordingDurationSeconds Int?
  providerCallSid   String?  // Twilio Call SID
  errorMessage      String?
  createdAt         DateTime @default(now())
  completedAt       DateTime?

  @@index([partnerCode])
  @@index([createdAt])
  @@index([providerCallSid])
}

// ─── WEBHOOK / API REQUEST LOG (Dev tools) ───────────────────────────────────
// Unified log for all API traffic visible in the developer panel:
//   direction="incoming" — requests received at /api/webhook/referral
//   direction="outgoing" — requests sent via the Custom API sender proxy
// Auth header values are redacted before storage. Bodies capped at 10 KB / 4 KB.
model WebhookRequestLog {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  direction      String   @default("incoming") // "incoming" | "outgoing"
  method         String   // GET, POST, PATCH, PUT, DELETE
  path           String   @default("/api/webhook/referral") // local path for incoming
  targetUrl      String?  // full URL for outgoing proxy calls
  sourceIp       String?  // caller IP for incoming; null for outgoing
  headers        String?  // JSON string — auth values replaced with [REDACTED]
  body           String?  // JSON string of request body (capped at 10 KB)
  responseStatus Int?     // HTTP status code
  responseBody   String?  // JSON string of response (capped at 4 KB)
  durationMs     Int?
  error          String?

  @@index([createdAt])
  @@index([direction])
  @@index([responseStatus])
}

// ─── WORKFLOWS & AUTOMATIONS ──────────────────────────────────────────────────
// Super-admin-only automation engine. Three models:
//   Workflow       — trigger + conditions + actions definition
//   WorkflowLog    — execution history per run
//   WebhookSource  — named incoming webhook sources (/api/webhook/[slug])

model Workflow {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  name          String
  description   String?
  enabled       Boolean       @default(true)
  // Trigger key — see TRIGGER_REGISTRY in src/lib/workflow-engine.ts
  trigger       String
  // Additional filter for the trigger, e.g. { "stage": "closedwon" }
  triggerConfig Json?
  // Optional condition array [{field, op, value}] — all must pass
  conditions    Json?
  // Action array [{type, config}] — executed in order
  actions       Json

  logs WorkflowLog[]

  @@index([trigger])
  @@index([enabled])
}

model WorkflowLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  triggerKey  String
  triggerData Json?    // snapshot of the event payload (trimmed for storage)
  // "success" | "failed" | "skipped"
  status      String   @default("success")
  actionsRun  Json?    // [{type, status, durationMs, error?}]
  error       String?
  durationMs  Int?

  @@index([workflowId])
  @@index([createdAt])
  @@index([status])
}

model WebhookSource {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  name         String
  // URL slug — becomes /api/webhook/{slug}
  slug         String    @unique
  // API key validated via x-api-key header
  apiKey       String    @unique @default(cuid())
  enabled      Boolean   @default(true)
  description  String?
  // Action array — same format as Workflow.actions
  actions      Json
  requestCount Int       @default(0)
  lastHitAt    DateTime?

  @@index([slug])
  @@index([enabled])
}

model AnnouncementChannel {
  id             String   @id @default(cuid())
  name           String
  description    String?
  createdByEmail String
  segmentRule    String?  // JSON: { filters: [{field, op, value}, ...] }
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships ChannelMembership[]
  messages    ChannelMessage[]
  threads     ChannelReplyThread[]

  @@index([createdByEmail])
  @@index([archivedAt])
}

model ChannelMembership {
  id           String    @id @default(cuid())
  channelId    String
  partnerCode  String
  source       String    // "manual" | "segment"
  addedByEmail String
  removedAt    DateTime? // soft remove; sticky across segment re-eval
  createdAt    DateTime  @default(now())

  channel AnnouncementChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, partnerCode])
  @@index([partnerCode])
  @@index([channelId, removedAt])
}

model ChannelMessage {
  id          String    @id @default(cuid())
  channelId   String
  authorEmail String
  authorName  String
  content     String
  messageType String    // "text" | "call_link"
  callMeta    String?   // JSON: {url, title, startsAt?, durationMins?, provider?}
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  channel AnnouncementChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}

model ChannelReplyThread {
  id            String   @id @default(cuid())
  channelId     String
  partnerCode   String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  channel  AnnouncementChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages ChannelReplyMessage[]

  @@unique([channelId, partnerCode])
  @@index([lastMessageAt])
}

model ChannelReplyMessage {
  id            String    @id @default(cuid())
  threadId      String
  senderType    String    // "admin" | "partner"
  senderEmail   String?   // admin email when senderType="admin"
  senderName    String
  content       String
  editedAt      DateTime?
  deletedAt     DateTime?
  readByAdmin   Boolean   @default(false)
  readByPartner Boolean   @default(false)
  createdAt     DateTime  @default(now())

  thread ChannelReplyThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// ─── PARTNER-TO-DOWNLINE DIRECT MESSAGING (Task 1) ───────────────────────────
model PartnerDmThread {
  id             String   @id @default(cuid())
  participantA   String   // partnerCode, lex-sorted so (A, B) is canonical (A < B)
  participantB   String
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())

  messages   PartnerDmMessage[]
  readStates PartnerDmReadState[]

  @@unique([participantA, participantB])
  @@index([participantA])
  @@index([participantB])
  @@index([lastMessageAt])
}

model PartnerDmMessage {
  id                String    @id @default(cuid())
  threadId          String
  senderPartnerCode String
  content           String
  editedAt          DateTime?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())

  thread PartnerDmThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  flags  PartnerDmFlag[]

  @@index([threadId, createdAt])
  @@index([senderPartnerCode])
}

model PartnerDmFlag {
  id                   String    @id @default(cuid())
  messageId            String
  flaggerPartnerCode   String
  reason               String?
  reviewedAt           DateTime?
  reviewedByAdminEmail String?
  verdict              String?   // "dismissed" | "confirmed"
  createdAt            DateTime  @default(now())

  message PartnerDmMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([reviewedAt])
  @@index([flaggerPartnerCode])
  @@index([messageId])
}

model PartnerDmThrottle {
  id            String    @id @default(cuid())
  partnerCode   String    @unique      // one active throttle record per sender
  state         String    // "throttled" | "suspended"
  reasonFlagId  String?                // which flag triggered this state
  startedAt     DateTime  @default(now())
  liftedAt      DateTime?              // null = active
}

model PartnerDmReadState {
  id          String   @id @default(cuid())
  threadId    String
  partnerCode String
  lastReadAt  DateTime @default(now())

  thread PartnerDmThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, partnerCode])
}

// ─── PASSWORD RESET TOKENS ──────────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  role      String   // "partner" | "admin"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ─── PUBLIC LANDING: PARTNER APPLICATIONS + BOOKING ─────────────────────────
// Public landing page at `/` collects leads from prospective referral
// partners. A PartnerApplication is a LEAD, NOT a Partner — it has no
// portal access and triggers zero automated communications until an admin
// explicitly approves it. Approval flow: admin reviews → qualification
// call (via Booking) → clicks "Approve & Send Invite" → existing
// RecruitmentInvite flow takes over (creates a standard L2 invite under
// the target upline code, defaulting to PTNS4XDMN). This preserves the
// invite-only partner rule.
model PartnerApplication {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String
  phone             String?
  companyName       String?
  website           String?
  // Free-text "tell us about your network / industry / client access"
  audienceContext   String?
  referralSource    String?   // how did you hear about us
  // Workflow status: new → contacted → qualified → approved → rejected
  status            String    @default("new")
  // Upline this applicant will be placed under when the invite fires.
  // Defaults to PTNS4XDMN (John Orlando) since the public landing page
  // lives under John's marketing funnel.
  uplineCode        String    @default("PTNS4XDMN")
  adminNotes        String?
  approvedAt        DateTime?
  approvedByAdminId String?
  rejectedAt        DateTime?
  rejectionReason   String?
  // RecruitmentInvite.id once the admin fires the invite flow from the
  // applications page. Null while the lead is still in qualification.
  inviteId          String?
  // UTM tracking for marketing attribution
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bookings Booking[]

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// Admin-defined time windows when John (or whoever) is available for
// qualification calls. Each slot has a capacity (1-5 seats) so one 30-min
// group call can screen multiple applicants.
model BookingSlot {
  id            String   @id @default(cuid())
  startsAt      DateTime
  endsAt        DateTime
  capacity      Int      @default(1)  // 1-5 seats
  location      String   @default("jitsi") // jitsi, zoom, phone, other
  title         String   @default("Partner Qualification Call")
  notes         String?
  status        String   @default("open") // open, closed, canceled
  // Google Calendar event id (created lazily on first booking). We attach
  // all bookers to the same event as guests so John sees one meeting on
  // his calendar, not one-per-applicant.
  googleEventId String?
  // Jitsi room name (derived from slot id). Same room shared by all
  // capacity seats in a single slot.
  jitsiRoom     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings Booking[]

  @@index([startsAt])
  @@index([status])
}

// A single applicant's reservation of one seat in a BookingSlot.
model Booking {
  id                 String   @id @default(cuid())
  slotId             String
  applicationId      String
  // Denormalized snapshot for display in admin / calendar events — the
  // application may be re-edited but the booking should reflect the
  // identity at reservation time.
  name               String
  email              String
  phone              String?
  status             String   @default("confirmed") // confirmed, canceled, no_show, completed
  canceledAt         DateTime?
  cancellationReason String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  slot        BookingSlot        @relation(fields: [slotId], references: [id], onDelete: Cascade)
  application PartnerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([slotId])
  @@index([applicationId])
  @@index([email])
}

// ─── LANDING PAGE CONTENT (singleton, admin-editable) ───────────────────────
// Data-driven landing page that lives at `/landing-v2` (hidden behind
// `landingV2Enabled`) and replaces `/` once published. Content is split
// into `draft` (what the admin editor writes) and `published` (what
// /landing-v2 renders). The `/api/admin/landing/regenerate` endpoint
// reads TrainingModule + TrainingResource (PDFs) + FAQ + PortalSettings
// and uses Claude to compose landing copy into `draft`.
//
// Both draft and published are JSON strings of the same shape (see
// src/lib/landingContent.ts for the TypeScript type). Storing as string
// keeps the schema stable as we add new sections — the editor + renderer
// both schema-validate on read.
model LandingContent {
  id                  String   @id @default("global") // singleton
  draft               String   @default("{}")
  published           String   @default("{}")
  landingV2Enabled    Boolean  @default(false) // flip to make /landing-v2 reachable (still hidden from /)
  landingV2Live       Boolean  @default(false) // flip to make `/` serve the new landing
  lastRegeneratedAt   DateTime?
  lastRegeneratedBy   String?  // admin id
  lastPublishedAt     DateTime?
  lastPublishedBy     String?  // admin id
  updatedAt           DateTime @updatedAt
}
