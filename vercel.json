{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && node scripts/seed-all.js && next build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/monthly-newsletter",
      "schedule": "0 14 1 * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 15 * * *"
    }
  ]
}
