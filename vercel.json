{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && node scripts/seed-all.js && next build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/monthly-newsletter",
      "schedule": "0 14 1 * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/conference-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/transcribe-recordings",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/import-meet-recordings",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/calendar-health",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/cbp-broker-sync",
      "schedule": "0 6 1 1,4,7,10 *"
    },
    {
      "path": "/api/cron/send-scheduled-emails",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/process-campaign-drips",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/research",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/deadline-alerts",
      "schedule": "0 12 * * *"
    }
  ]
}
